    "hammerjs": "^2.0.8",
    "jquery": "^3.5.1",
    "js-yaml": "^4.1.1",
    "leaflet": "^1.9.4",
    "sass-embedded": "^1.93.3",
    "satellite.js": "^7.0.1",
